# Claude API (필수: AI 해석 사용 시)
ANTHROPIC_API_KEY=sk-ant-...

# LLM 모델 (기본값: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# 타임존 (리포트 날짜 기준)
TZ=America/New_York

# 옵션: AI 해석 비활성화 (룰 기반만 사용)
DISABLE_AI=false

# 옵션: Alpaca 데이터 fallback (https://alpaca.markets/ 무료 가입)
# yfinance 누락 종목이 있을 때만 보완 호출. 없어도 동작.
ALPACA_API_KEY=
ALPACA_SECRET=

# 옵션: FRED 거시 지표 (https://fred.stlouisfed.org/docs/api/api_key.html 무료)
# 실업률, CPI, 정책금리, 10Y-2Y spread 등. 없으면 skip.
FRED_API_KEY=
